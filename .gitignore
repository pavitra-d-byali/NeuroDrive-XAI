__pycache__/
*.pyc
.ipynb_checkpoints/

# Ignore massive Neural Network weights & Pickles (GitHub blocks >100MB)
weights/
*.pth
*.pkl

# Ignore heavy video/image artifacts locally generated
artifacts/*.mp4
artifacts/*.jpg
demo/
*.mp4

# OS generated files
.DS_Store
Thumbs.db

# Virtual environments
venv/
env/
.env
